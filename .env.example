# ─────────────────────────────────────────────────────────────────────────────
# PP Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values
#   3. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM PROVIDER (auto-detect if blank) ──────────────────────────────────────
# Priority: minimax → claude → openai → gemini → openrouter
# Override: minimax | claude | openai | gemini | openrouter
LLM_PROVIDER=
LLM_MODEL=

# ── MINIMAX (default — Token Plan key starts with sk-cp-) ─────────────────────
# Token Plan: 1,500 requests per 5-hour window
# Get key: https://platform.minimax.io/user-center/payment/token-plan
MINIMAX_API_KEY=sk-cp-your-minimax-token-plan-key-here

# ── ANTHROPIC CLAUDE ──────────────────────────────────────────────────────────
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPENAI ────────────────────────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── GOOGLE GEMINI ─────────────────────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OPENROUTER ────────────────────────────────────────────────────────────────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── MICROSOFT AZURE APP REGISTRATION ─────────────────────────────────────────
# Create in Azure Portal → Entra ID → App Registrations
# Required API permissions:
#   - Dynamics CRM → user_impersonation
#   - Power Automate Service → Flows.Read.All + Flows.Manage.All
#   - PowerApps Service → User
#   - Azure Service Management → user_impersonation
# Redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
PP_CLIENT_ID=your-azure-app-client-id-here
PP_TENANT_ID=common
# Optional: for service principal / headless auth (no device code needed)
PP_CLIENT_SECRET=

# ── POWER PLATFORM ENVIRONMENT ────────────────────────────────────────────────
# Your Dataverse environment URL — change this to switch environments
PP_ENV_URL=https://yourorg.crm11.dynamics.com
PP_ENV_NAME=CRM Demo

# ── POWER PLATFORM ENVIRONMENT ID ────────────────────────────────────────────
# Needed for Power Automate + Canvas App + DLP APIs
# Find it: Admin Center → Environments → select env → Details → Environment ID
PP_ENV_ID=your-environment-id-guid-here

# ── GEOGRAPHY (for Power Automate API routing) ────────────────────────────────
PP_GEO=unitedstates

# ── AZURE DEVOPS (optional) ───────────────────────────────────────────────────
# Create PAT: https://dev.azure.com → User Settings → Personal Access Tokens
# Required scopes: Work Items (Read & Write), Build (Read & Execute), Code (Read)
ADO_ORG=your-ado-org-name
ADO_PAT=your-azure-devops-personal-access-token
ADO_PROJECT=your-default-project-name

# ── FLASK ─────────────────────────────────────────────────────────────────────
PORT=5005
FLASK_SECRET=change-this-to-a-random-secret
